# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (สำหรับ Google Login) ──────────────────────────────────────
# สร้างจาก: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google Sheets Integration ────────────────────────────────────────────────
# Spreadsheet ID จาก URL ของ Google Sheets
GOOGLE_SHEETS_ID=your-spreadsheet-id

# Apps Script Web App URL (หลัง Deploy as Web App)
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec
APPS_SCRIPT_API_KEY=your-api-key-for-security

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MERIDIAN ROOM AI
NEXT_PUBLIC_APP_VERSION=2.0.0
