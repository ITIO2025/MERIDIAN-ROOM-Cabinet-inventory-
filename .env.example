# ════════════════════════════════════════════════════════════════════
#  MERIDIAN ROOM AI — Environment Variables
#  คัดลอกไฟล์นี้เป็น .env.local แล้วกรอกค่าให้ครบ
# ════════════════════════════════════════════════════════════════════

# ─── NextAuth (REQUIRED) ──────────────────────────────────────────
# สร้าง secret ด้วย: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_32_CHARS
# URL ของเว็บคุณ (ไม่มี trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app

# ─── App Info ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MERIDIAN ROOM AI
NEXT_PUBLIC_APP_VERSION=2.0.0

# ─── Google OAuth (Optional) ──────────────────────────────────────
# เปิดที่ https://console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
NEXT_PUBLIC_GOOGLE_ENABLED=false

# ─── Google Sheets Sync (Optional) ───────────────────────────────
# ตั้งค่าในหน้า Settings ของแอป (ไม่ต้องใส่ใน env)
# APPS_SCRIPT_URL=https://script.google.com/macros/s/xxx/exec
